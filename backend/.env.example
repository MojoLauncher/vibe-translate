# Required: GitHub OAuth App credentials (for user identification only)
# Create an OAuth App at https://github.com/settings/developers
# Set the callback URL to: http://localhost:3000/auth/github/callback
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here

# Required: GitHub bot token with write access to the target repository
# Generate a Personal Access Token from a bot account at:
# https://github.com/settings/tokens (classic, scope: repo)
GITHUB_BOT_TOKEN=your_github_bot_token_here

# Required: GitHub login of the user who can manage the ban list
GITHUB_ADMIN_LOGIN=your_github_username

# Optional overrides
# PORT=3000
# NODE_ENV=development
# SESSION_SECRET=generate-a-random-string-here
# FRONTEND_URL=http://localhost:3000

# Optional: target repository configuration (defaults match the frontend)
# GITHUB_REPO_OWNER=MojoLauncher
# GITHUB_REPO_NAME=MojoLauncher
# GITHUB_BRANCH=v3_openjdk
# RES_PATH=app_pojavlauncher/src/main/res
